# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# NextGenAMS Agent Engine — Environment Variables Template
# Copy this file to .env for local development.
# NEVER commit .env to version control.
# All values marked TBC need to be provided by XYZ team.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service Identity ──────────────────────────────────────────────────────────
SERVICE_NAME=nextgenams-agent-engine
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── GenAI Shared Service ──────────────────────────────────────────────────────
# TBC from XYZ team
GENAI_BASE_URL=
GENAI_API_KEY=
GENAI_MODEL_SMART=gpt-4o
GENAI_MODEL_FAST=gpt-4o-mini
GENAI_TEMPERATURE=0.0
GENAI_MAX_TOKENS=2000

# ── Vector API (Knowledge Base) ───────────────────────────────────────────────
# TBC from  team — URL, auth method, request/response format all needed
VECTOR_API_URL=
VECTOR_API_KEY=
VECTOR_TOP_K=3

# ── ServiceNow ────────────────────────────────────────────────────────────────
# TBC from XYZ team — manual ticket URL for Phase 1
SERVICENOW_TICKET_URL=

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Use local MongoDB for dev: mongodb://localhost:27017
# Atlas connection string for staging/production
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=nextgenams

# ── Auth — JWT Validation ─────────────────────────────────────────────────────
# Set AUTH_ENABLED=false for local development (bypasses JWT validation)
# Set AUTH_ENABLED=true for staging and production ALWAYS
AUTH_ENABLED=false
AUTH_JWKS_URL=
AUTH_AUDIENCE=
AUTH_ALGORITHM=RS256

# ── JWT Claim Mapping ─────────────────────────────────────────────────────────
# Run GET /debug/token-claims in dev to find the correct claim field names
# Entra ID: USER_ID_CLAIM=oid
# OpenAM:   USER_ID_CLAIM=sub  or  USER_ID_CLAIM=uid
USER_ID_CLAIM=oid
USER_EMAIL_CLAIM=preferred_username
USER_NAME_CLAIM=name
USER_ROLES_CLAIM=roles

# ── Conversation Settings ─────────────────────────────────────────────────────
MAX_MESSAGES_IN_CONTEXT=10
CONVERSATION_HISTORY_LIMIT=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: allow all origins
# Production:  set to Angular app URL e.g. https://nextgenams.XYZ.com
CORS_ORIGINS=["*"]

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production: Azure Redis Cache — get connection string from Key Vault
REDIS_URL=redis://localhost:6379
REDIS_PROMPT_CHANNEL=nextgenams:prompt_invalidated
